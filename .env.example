# Supabase project URL and public anon key
NEXT_PUBLIC_SUPABASE_URL="https://your-project-ref.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"

# Server-side only Supabase key (optional, for admin/server flows in future issues)
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Prisma (Postgres) connection strings
DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:5432/data_vault"
DIRECT_URL="postgresql://postgres:postgres@127.0.0.1:5432/data_vault"

# Seed defaults
DEFAULT_ADMIN_USER_ID="00000000-0000-0000-0000-000000000000"
DEFAULT_ADMIN_EMAIL="admin@datavault.app"

# Gemini API Key
GEMINI_API_KEY=